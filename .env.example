# =========================================
# Athenec - Variables de entorno (plantilla)
# Copia este archivo como `.env` y completa los valores
# =========================================

# ---- Entorno de ejecucion ----
ENVIRONMENT=development   # development | staging | production
DEBUG=True

# ---- Servidor / API ----
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

# ---- Base de datos (SQL) ----
# Ejemplo local (SQLite):
DATABASE_URL=sqlite:///./athenec.db
# Ejemplo produccion (PostgreSQL / AWS RDS):
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/athenec

# ---- Seguridad ----
SECRET_KEY=cambia-esta-clave-en-produccion
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- CORS ----
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:3000

# ---- AWS (para despliegue futuro) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ---- Correo (notificaciones de cotizacion) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
CONTACT_EMAIL=contacto@athenec.com
